# ============================================================================
# Production Environment Variables (Netlify)
# ============================================================================
# These variables must be set in Netlify UI for the HOST application
# DO NOT commit this file with real values - it's just a template
#
# How to set in Netlify:
# 1. Go to Site Settings → Environment Variables
# 2. Add each variable below with your actual Netlify URLs
# ============================================================================

# ============================================================================
# Remote Applications URLs (Netlify Deployments)
# ============================================================================
# Replace these placeholder URLs with your actual Netlify deployment URLs
# after deploying each remote application
#
# Format: https://[your-site-name].netlify.app
# ============================================================================

# Host URL (not used in production, but kept for consistency)
# VITE_HOST_URL=your-host-app.netlify.app

# Home Remote URL (deployed on Netlify)
VITE_HOME_URL=https://your-home-app.netlify.app

# Media Remote URL (deployed on Netlify)
VITE_MEDIA_URL=https://your-media-app.netlify.app

# Photos Remote URL (deployed on Netlify)
VITE_PHOTOS_URL=https://your-photos-app.netlify.app

# ============================================================================
# API Keys and Secrets (Production)
# ============================================================================
# Set these in Netlify UI - never commit real values to git
# ============================================================================

# TMDB API Key (production)
# VITE_TMDB_API_KEY=your_production_api_key

# ============================================================================
# Sentry implementation (Production)
# ============================================================================
# Add your production API keys here
# Never commit this file to git!
# ============================================================================
# Sentry (VITE_ = public DSN, baked at build time — safe to expose)
VITE_SENTRY_DSN=

# Sentry build tools (no VITE_ prefix — never embedded in bundles)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Sentry account
VITE_SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug

# ============================================================================
# IMPORTANT NOTES
# ============================================================================
# 1. These variables are ONLY needed for the HOST application
# 2. Remotes (home, media, photos) don't need these variables
# 3. Set these in Netlify UI: Site Settings → Environment Variables
# 4. After first deployment, update with real Netlify URLs
# ============================================================================
