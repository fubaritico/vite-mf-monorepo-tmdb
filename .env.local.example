# ============================================================================
# Local Development Environment Variables
# ============================================================================
# Copy this file to .env.local for local development
# .env.local is gitignored and will override .env values
#
# Usage: cp .env.local.example .env.local
# ============================================================================

# ============================================================================
# Development Server URLs (localhost)
# ============================================================================
# These URLs are used in development mode for Module Federation
# The host loads remotes from these localhost addresses
# Format: http://localhost:PORT
# ============================================================================

# Host URL (for HMR notifications from remotes)
VITE_HOST_URL=localhost:3000

# Remote URLs for Module Federation (development)
VITE_HOME_URL=http://localhost:3001
VITE_MEDIA_URL=http://localhost:3002
VITE_PHOTOS_URL=http://localhost:3003

# ============================================================================
# API Keys and Secrets (Development)
# ============================================================================
# Add your development API keys here
# Never commit this file to git!
# ============================================================================

# TMDB API Key (get yours at https://www.themoviedb.org/settings/api)
# VITE_TMDB_API_KEY=your_dev_api_key_here
