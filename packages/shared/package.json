{
  "name": "@vite-mf-monorepo/shared",
  "version": "0.0.2",
  "type": "module",
  "publishConfig": {
    "access": "restricted"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "import": "./dist/vite/index.js"
    },
    "./mocks": {
      "types": "./dist/mocks/index.d.ts",
      "import": "./dist/mocks/index.js"
    },
    "./test-utils": {
      "types": "./dist/test-utils/index.d.ts",
      "import": "./dist/test-utils/index.js"
    },
    "./src/tailwind/theme.css": "./src/tailwind/theme.css",
    "./src/tailwind/theme-no-fonts.css": "./src/tailwind/theme-no-fonts.css",
    "./src/fonts/fonts.css": "./src/fonts/fonts.css",
    "./assets": {
      "types": "./dist/assets/index.d.ts",
      "import": "./dist/assets/index.js"
    }
  },
  "scripts": {
    "svg": "node ./script/export-svgs.js",
    "build": "pnpm svg && tsc && mkdir -p dist/assets && mv dist/.temp-svg/* dist/assets/ 2>/dev/null && rm -rf dist/.temp-svg src/.temp-svg || true",
    "dev": "tsc --watch",
    "lint": "eslint ./src",
    "lint:fix": "eslint ./src --fix",
    "local-release:patch": "pnpm build && ./publish-local.sh patch",
    "local-release:minor": "pnpm build && ./publish-local.sh minor",
    "local-release:major": "pnpm build && ./publish-local.sh major",
    "release:patch": "pnpm build && ./publish.sh patch",
    "release:minor": "pnpm build && ./publish.sh minor",
    "release:major": "pnpm build && ./publish.sh major"
  },
  "dependencies": {
    "@fubar-it-co/tmdb-client": "workspace:*",
    "@vite-mf-monorepo/tokens": "workspace:*",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router-dom": "catalog:",
    "svg-to-jsx": "^1.0.4",
    "svgr": "^2.0.0"
  },
  "peerDependencies": {
    "@tanstack/react-query": "catalog:",
    "@testing-library/react": "catalog:"
  },
  "devDependencies": {
    "@fontsource/inter": "catalog:",
    "@fontsource/roboto": "catalog:",
    "@fontsource/roboto-condensed": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "conventional-changelog": "catalog:",
    "glob": "13.0.6",
    "msw": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
